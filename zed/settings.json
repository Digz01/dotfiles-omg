{
  // THE MOST IMPORTANT
  "hover_popover_hiding_delay": 0,
  "hover_popover_delay": 10000,
  "snippet_sort_order": "bottom",
  "edit_predictions": {
    "allow_data_collection": "no",
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "default_model": {
      "effort": "medium",
      "provider": "google",
      "model": "gemini-3.5-flash",
      "enable_thinking": true,
    },
    "play_sound_when_agent_done": "never",
    "single_file_review": true,
    "thinking_display": "auto",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "show_signature_help_after_edits": false,
  "auto_signature_help": false,
  "disable_ai": false,

  // =========================
  // Editor Appearance
  // =========================
  "show_whitespaces": "boundary",
  "icon_theme": {
    "mode": "light",
    "light": "JetBrains Icons Dark",
    "dark": "JetBrains Icons Dark",
  },
  "hard_tabs": false,
  "indent_guides": {
    "background_coloring": "disabled",
  },
  "colorize_brackets": true,
  "always_treat_brackets_as_autoclosed": true,
  "inlay_hints": {
    "show_other_hints": false,
    "show_parameter_hints": true,
    "show_type_hints": false,
    "show_value_hints": true,
  },
  "line_indicator_format": "long",
  "ui_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_size": 16,
  "buffer_font_size": 15.4,

  "lsp_document_colors": "border",
  // "wrap_guides": [79],
  "soft_wrap": "editor_width",
  "show_edit_predictions": true,

  // Theme & Colors
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Compline",
  },
  "current_line_highlight": "all",

  "experimental.theme_overrides": {
    "background.appearance": "transparent",
    "syntax": {
      "keyword": { "color": "#9D70FF" },
      // "function": { "color": "#BCBEC4" },
    },
  },

  // =========================
  // Editor Behavior
  // =========================
  "vim_mode": true,
  "autosave": {
    "after_delay": { "milliseconds": 500 },
  },
  "format_on_save": "off",
  "restore_on_startup": "last_session",
  "show_completions_on_input": true,
  "show_completion_documentation": false,

  // =========================
  // Git Integration
  // =========================
  "git": {
    "inline_blame": { "enabled": true },
  },

  // =========================
  // Language-Specific Settings
  // =========================
  //

  "inline_code_actions": true,
  "languages": {
    "Python": {
      "language_servers": ["pyright"],
      "always_treat_brackets_as_autoclosed": true,
      "use_auto_surround": true,
      "use_autoclose": true,
      "extend_comment_on_newline": false,
      "formatter": {
        "external": {
          "command": "autopep8",
          "arguments": ["-", "-a"],
          // "arguments": ["-", "--skip-string-normalization"],
        },
      },
      "format_on_save": "off",
    },
  },

  "lsp": {
    "pyright": {
      "settings": {
        "python": {
          "analysis": {
            "typeCheckingMode": "basic",
            "diagnosticSeverityOverrides": {
              "reportPrivateImportUsage": "none",
              "reportMissingImports": "none",
              "reportMissingModuleSource": "none"
            }
          }
        }
      }
    }
  },


  // =========================
  // Privacy & Telemetry
  // =========================
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
